# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.

# Anthropic API key — required to run skill evals
ANTHROPIC_API_KEY=your-key-here

# Point at a LiteLLM proxy instead of Anthropic directly (e.g. corporate hosted models)
ANTHROPIC_BASE_URL=https://your-litellm-proxy.example.com

# Model slug as configured in your LiteLLM proxy
ANTHROPIC_MODEL=your-model-slug-here

# Override claude binary path if auto-detection fails
# CLAUDE_PATH=/usr/local/bin/claude
